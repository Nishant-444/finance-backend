{
	"info": {
		"name": "Finance Backend API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8000" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "recordId", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"viewer\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/auth/register"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/auth/login"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"pm.collectionVariables.set('refreshToken', res.data.refreshToken);"
								]
							}
						}
					]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/auth/refresh-token"
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/auth/logout"
					}
				}
			]
		},
		{
			"name": "Records",
			"item": [
				{
					"name": "Create Record (admin)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 125.5,\n  \"type\": \"credit\",\n  \"category\": \"salary\",\n  \"date\": \"2026-04-05T12:00:00.000Z\",\n  \"notes\": \"April payout\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/records"
					}
				},
				{
					"name": "Get Records",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/records?startDate=2026-01-01&endDate=2026-12-31&type=credit&category=salary"
					}
				},
				{
					"name": "Update Record (admin)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 150,\n  \"notes\": \"Adjusted amount\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/records/{{recordId}}"
					}
				},
				{
					"name": "Delete Record (admin)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/records/{{recordId}}"
					}
				}
			]
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Summary",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/dashboard/summary"
					}
				}
			]
		},
		{
			"name": "Users (admin)",
			"item": [
				{
					"name": "Get Users",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/users"
					}
				},
				{
					"name": "Get User By Id",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": "{{baseUrl}}/api/v1/users/{{userId}}"
					}
				},
				{
					"name": "Update User Role",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"analyst\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/users/{{userId}}/role"
					}
				},
				{
					"name": "Update User Status",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"active\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/users/{{userId}}/status"
					}
				}
			]
		}
	]
}
